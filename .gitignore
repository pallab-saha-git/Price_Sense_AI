# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.tox/
*.spec

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.local
.env.production

# ── Secrets — NEVER commit real credentials ───────────────────────────────────
.env
*.pem
*.key
*.p12

# ── Docker override (contains real credentials) ───────────────────────────────
docker-compose.override.yml

# ── Database files ────────────────────────────────────────────────────────────
data/*.db
data/*.sqlite
data/*.sqlite3
# SQLite WAL / shared-memory side-files (auto-generated, never commit)
*.db-shm
*.db-wal
*.db-journal

# ── Large raw dataset downloads — NEVER commit to git ─────────────────────────
# Zips (dunnhumby, Kaggle, etc.)
data/zip/
*.zip
# Raw / processed pipeline directories
data/raw/
data/processed/
# Dunnhumby ingestion sentinel
data/.dunnhumby_loaded
# Partial downloads
data/zip/*.partial

# ── Generated synthetic data CSVs ─────────────────────────────────────────────
# These are auto-generated by data/synthetic_generator.py — do NOT commit them.
# Docker regenerates them at build time (RUN step) and at container startup
# (CMD guard) so a fresh clone always works without any manual step.
data/synthetic/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Coverage / test artefacts ─────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
*.lcov

# ── Distribution ──────────────────────────────────────────────────────────────
*.tar.gz
*.whl

# ── Docker ────────────────────────────────────────────────────────────────────
# Note: .dockerignore is intentionally tracked (project config)
docker-compose.override.yml.local

# ── ML model artefacts (can be large) ────────────────────────────────────────
models/saved/
*.pkl
*.joblib
*.h5
*.pt
*.onnx

tests/*
