# ─────────────────────────────────────────────────────────────────────────────
# Price Sense AI — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — no install required):
DATABASE_URL=sqlite:///./data/pricesense.db
# PostgreSQL example (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/pricesense

# ── App server ────────────────────────────────────────────────────────────────
DEBUG=false
HOST=0.0.0.0
PORT=8050

# ── Secret key (Flask session signing) ───────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── AI Insights — OpenRouter ─────────────────────────────────────────────────
# Get your free API key at https://openrouter.ai
# Free tier models require no payment details.
OPEN_ROUTER_API_KEY=

# Model to use for AI insights.
# Default (free, no cost): meta-llama/llama-3.3-70b-instruct:free
# Other free options:
#   google/gemma-3-27b-it:free
#   openai/gpt-oss-120b:free
#   qwen/qwen3-coder:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Admin bootstrap (first-run only) ─────────────────────────────────────────
# Used to seed the first admin account on first startup.
# After the admin is created you can change/remove these.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Optional: restrict sign-ups ──────────────────────────────────────────────
# Set to "true" to disable the public registration page.
REGISTRATION_DISABLED=false
